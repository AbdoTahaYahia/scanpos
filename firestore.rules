rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStoreManager(storeId) {
      let userData = getUserData();
      return userData.storeId == storeId && userData.role == 'manager';
    }

    function isStoreMember(storeId) {
      let userData = getUserData();
      return userData.storeId == storeId && userData.role in ['manager', 'employee'];
    }

    function hasRole(storeId, role) {
      let userData = getUserData();
      return userData.storeId == storeId && (
        userData.role == 'manager' ||
        (
          userData.role == 'employee' &&
          userData.roles is list &&
          role in userData.roles
        )
      );
    }

    function hasOnlyAllowedEmployeeRoles(roles) {
      return roles is list &&
        roles.size() > 0 &&
        roles.hasOnly(['cashier', 'warehouse']);
    }

    function isValidNewUser() {
      return request.resource.data.uid == request.auth.uid &&
        (
          (
            request.resource.data.role == 'manager' &&
            request.resource.data.roles == [] &&
            request.resource.data.storeId is string &&
            get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.managerId == request.auth.uid
          ) ||
          (
            request.resource.data.role == 'pending' &&
            request.resource.data.roles == [] &&
            request.resource.data.storeId is string
          )
        );
    }

    function isSafeOwnerProfileUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['displayName', 'photoUrl', 'email']);
    }

    function isValidManagerUserUpdate() {
      return request.resource.data.uid == resource.data.uid &&
        (
          (
            request.resource.data.storeId == resource.data.storeId &&
            request.resource.data.role == 'employee' &&
            hasOnlyAllowedEmployeeRoles(request.resource.data.roles)
          ) ||
          (
            request.resource.data.storeId == null &&
            request.resource.data.role == 'pending' &&
            request.resource.data.roles == []
          )
        );
    }

    // ─── Users Collection ─────────────────────────────────────────
    // Users can read/write their own document
    // Store managers can read employees of their store
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) ||
        (resource.data.storeId != null && isStoreManager(resource.data.storeId))
      );
      allow create: if isAuthenticated() && isOwner(userId) && isValidNewUser();
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isSafeOwnerProfileUpdate()) ||
        (isStoreManager(resource.data.storeId) && isValidManagerUserUpdate())
      );
      allow delete: if false; // No user deletion from client
    }

    // ─── Stores Collection ────────────────────────────────────────
    match /stores/{storeId} {
      // Any authenticated user can read a store (needed for invite code lookup)
      allow read: if isAuthenticated();
      // Only the manager can create/update their store
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isStoreManager(storeId);
      allow delete: if false;

      // ─── Products Sub-collection ──────────────────────────────
      match /products/{productId} {
        // Store members can read products
        allow read: if isAuthenticated() && isStoreMember(storeId);
        // Manager and warehouse roles can write products
        allow create, delete: if isAuthenticated() && (
          isStoreManager(storeId) || hasRole(storeId, 'warehouse')
        );
        allow update: if isAuthenticated() && (
          isStoreManager(storeId) || hasRole(storeId, 'warehouse')
        );
      }

      // ─── Transactions Sub-collection ──────────────────────────
      match /transactions/{transactionId} {
        // Only managers can read transactions
        allow read: if isAuthenticated() && isStoreManager(storeId);
        allow create: if false; // Checkout writes must go through Cloud Functions
        allow update, delete: if false; // Transactions are immutable
      }
    }
  }
}
